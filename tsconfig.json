{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@pages/*": [
        "./src/app/*"
      ],
      "@components/*": [
        "./src/components/*"
      ],
      "@providers/*": [
        "./src/providers/*"
      ],
      "@fixtures/*": [
        "./tests/fixtures/*"
      ]
    },
    "target": "ES2017"
  },
  "typedocOptions": {
    "name": "Jack Maclennan Portfolio",
    "entryPoints": [
      "src/**",
      "tests/fixtures/**"
    ],
    "exclude": [
      "**/node_modules/**",
      "**/dist/**",
      "**/build/**",
      "**/.next/**",
      "**/out/**"
    ],
    "out": "jack-maclennan-portfolio-docs/docs",
    "plugin": [
      "typedoc-plugin-merge-modules",
      "typedoc-plugin-include-example",
      "typedoc-plugin-github-widget",
      "typedoc-plugin-inline-sources",
      "typedoc-plugin-missing-exports"
    ],
    "includeDocCommentReferences": true,
    "internalModule": "Not Exported",
    "placeInternalsInOwningModule": true,
    "mergeModulesRenameDefaults": true,
    "mergeModulesMergeMode": "module",
    "githubWidgetUrl": "https://github.com/maclenjack/jack-maclennan-portfolio",
    "sort": [
      "source-order"
    ],
    "highlightLanguages": [
      "typescript",
      "tsx"
    ],
    "navigationLinks": {
      "Website": "https://jack-maclennan-portfolio.vercel.app/"
    },
    "markdownItOptions": {
      "html": true
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
